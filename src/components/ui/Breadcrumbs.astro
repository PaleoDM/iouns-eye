---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm text-text-secondary mb-4">
  <ol class="flex flex-wrap items-center gap-1">
    {items.map((item, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span class="text-border">/</span>}
        {item.href && i < items.length - 1 ? (
          <a href={item.href} class="hover:text-accent transition-colors">{item.label}</a>
        ) : (
          <span class={i === items.length - 1 ? 'text-text-primary' : ''}>{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
