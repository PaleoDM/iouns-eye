---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatusBadge from '../components/ui/StatusBadge.astro';
import { getCollection } from 'astro:content';
import { COLLECTIONS, collectionUrl, type CollectionName } from '../lib/collections';

const npcs = await getCollection('npcs');
const locations = await getCollection('locations');
const factions = await getCollection('factions');
const events = await getCollection('events');
const items = await getCollection('items');
const deities = await getCollection('deities');
const lore = await getCollection('lore');
const campaignEntries = await getCollection('campaigns');
const chronicles = await getCollection('chronicles');
const pcs = await getCollection('pcs');

const counts: Record<CollectionName, number> = {
  npcs: npcs.length,
  locations: locations.length,
  factions: factions.length,
  events: events.length,
  items: items.length,
  deities: deities.length,
  lore: lore.length,
  campaigns: campaignEntries.length,
  chronicles: chronicles.length,
  pcs: pcs.length,
};

const totalEntries = Object.values(counts).reduce((a, b) => a + b, 0);

// Sort campaigns: active first, then by start_year desc
const sortedCampaigns = [...campaignEntries].sort((a, b) => {
  const statusOrder = { active: 0, hiatus: 1, completed: 2, defunct: 3 };
  const aOrder = statusOrder[a.data.status as keyof typeof statusOrder] ?? 4;
  const bOrder = statusOrder[b.data.status as keyof typeof statusOrder] ?? 4;
  if (aOrder !== bOrder) return aOrder - bOrder;
  return (b.data.start_year ?? 0) - (a.data.start_year ?? 0);
});

const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title="Home">
  <!-- Hero -->
  <div class="text-center py-10 lg:py-16">
    <img src={`${baseUrl}logo.png`} alt="Ioun's Eye" class="mx-auto h-32 lg:h-40 mb-6" />
    <h1 class="text-4xl lg:text-5xl font-serif text-accent mb-3">Ioun's Eye</h1>
    <p class="text-text-secondary text-lg max-w-2xl mx-auto leading-relaxed">
      The living encyclopedia of Astoria — a world spanning continents, centuries, and countless stories.
      Named for Ioun, the Knowing Mistress, goddess of all knowledge.
    </p>
    <p class="text-text-secondary mt-3">
      <span class="text-accent font-semibold">{totalEntries}</span> entries across {Object.keys(counts).length} collections
    </p>
  </div>

  <!-- Stats grid -->
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3 mb-12">
    {(Object.entries(COLLECTIONS) as [CollectionName, typeof COLLECTIONS[CollectionName]][]).map(([key, meta]) => (
      <a href={collectionUrl(key)} class="bg-surface border border-border rounded-lg p-4 text-center hover:bg-surface-hover hover:border-accent/50 transition-colors">
        <span class="text-2xl">{meta.icon}</span>
        <p class="text-2xl font-serif text-text-primary mt-1">{counts[key]}</p>
        <p class="text-xs text-text-secondary uppercase tracking-wider mt-0.5">{meta.label}</p>
      </a>
    ))}
  </div>

  <!-- Campaigns -->
  <section class="mb-12">
    <h2 class="text-2xl font-serif text-text-primary mb-6">Campaigns</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {sortedCampaigns.map((campaign) => (
        <a href={`${baseUrl}campaigns/${campaign.id}/`} class="bg-surface border border-border rounded-lg p-5 hover:bg-surface-hover hover:border-accent/50 transition-colors">
          <div class="flex items-start justify-between gap-2">
            <h3 class="font-serif text-lg text-text-primary">{campaign.data.name}</h3>
            <StatusBadge status={campaign.data.status} />
          </div>
          <div class="flex flex-wrap gap-x-4 gap-y-1 mt-2 text-sm text-text-secondary">
            {campaign.data.start_year && (
              <span>{campaign.data.start_year}{campaign.data.end_year ? `–${campaign.data.end_year}` : ''} TA</span>
            )}
            {campaign.data.continent && <span>{campaign.data.continent}</span>}
            {campaign.data.session_count && <span>{campaign.data.session_count} sessions</span>}
            {campaign.data.party.length > 0 && <span>{campaign.data.party.length} party members</span>}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Browse by category -->
  <section>
    <h2 class="text-2xl font-serif text-text-primary mb-6">Browse the Codex</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {([
        ['npcs', 'Characters of the world'],
        ['locations', 'Places across Astoria'],
        ['factions', 'Powers and organizations'],
        ['events', 'History unfolding'],
        ['items', 'Legendary artifacts and tools'],
        ['deities', 'The divine pantheon'],
        ['lore', 'World-building and cosmology'],
        ['pcs', 'Player characters across campaigns'],
        ['chronicles', 'Player-written narratives'],
      ] as [CollectionName, string][]).map(([key, desc]) => (
        <a href={collectionUrl(key)} class="bg-surface border border-border rounded-lg p-5 hover:bg-surface-hover hover:border-accent/50 transition-colors">
          <div class="flex items-center gap-2">
            <span class="text-lg">{COLLECTIONS[key].icon}</span>
            <h3 class="font-serif text-text-primary">{COLLECTIONS[key].label}</h3>
          </div>
          <p class="text-text-secondary text-sm mt-1">{desc}</p>
          <p class="text-accent text-sm mt-2">{counts[key]} entries</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
