---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import StatusBadge from '../../components/ui/StatusBadge.astro';
import { entryUrl, COLLECTIONS, type CollectionName } from '../../lib/collections';

export async function getStaticPaths() {
  const entries = await getCollection('campaigns');
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const baseUrl = import.meta.env.BASE_URL;

// Portrait lookup
const PORTRAITS: Record<string, string> = {
  'tyrell': 'tyrell.jpg',
  'veil': 'veil.jpg',
  'thorn': 'thorn.png',
  'arden': 'arden.jpg',
  'quin': 'quin.png',
  'leon': 'leon.png',
  'freddie': 'freddie.png',
  'azrael': 'azrael.png',
  'vicas': 'vicas.jpg',
  'lyra': 'lyra.jpg',
  'rooker': 'rooker.jpg',
  'thump': 'thump.png',
};

const partyWithPortraits = d.party.map((member) => ({
  ...member,
  portrait: member.slug && PORTRAITS[member.slug] ? `${baseUrl}portraits/${PORTRAITS[member.slug]}` : null,
  initials: member.name.charAt(0).toUpperCase(),
}));

// Map continent to map image(s)
const CONTINENT_MAPS: Record<string, Array<{ file: string; label: string }>> = {
  'Wanun': [
    { file: 'wanun.jpg', label: 'Wanun' },
    { file: 'ekkorai.jpg', label: 'Ekkorai (Detail)' },
  ],
  'Khanae': [
    { file: 'khanae.jpg', label: 'Khanae' },
  ],
  'Glennox': [],
};
const campaignMaps = d.continent ? (CONTINENT_MAPS[d.continent] ?? []) : [];

// Breadcrumb
const breadcrumbParent = d.status === 'completed'
  ? { label: 'Archive', href: `${baseUrl}archive/` }
  : null;

const campaignId = entry.id;

// Fetch real recaps for this campaign
const allRecaps = await getCollection('recaps', ({ data }) => data.campaign === campaignId);

// Sort ascending for arc computation, descending for display
const recapsAsc = [...allRecaps].sort((a, b) => a.data.session_number - b.data.session_number);
const recapsDesc = [...allRecaps].sort((a, b) => b.data.session_number - a.data.session_number);

// Render all recap bodies (static generation — fine at build time)
const recapsWithContent = await Promise.all(
  recapsDesc.map(async (r) => ({ data: r.data, rendered: await render(r) }))
);

// Build arc sidebar: ordered unique arcs with session ranges
const arcMap = new Map<string, { first: number; last: number }>();
for (const r of recapsAsc) {
  const arc = r.data.arc_name;
  if (!arc) continue;
  if (!arcMap.has(arc)) {
    arcMap.set(arc, { first: r.data.session_number, last: r.data.session_number });
  } else {
    arcMap.get(arc)!.last = r.data.session_number;
  }
}
const arcs = [...arcMap.entries()].map(([name, { first, last }]) => ({
  name,
  sessions: first === last ? `${first}` : `${first}–${last}`,
}));

// Fetch campaign-scoped entities for tabbed grimoire
const ENTITY_COLS: CollectionName[] = ['npcs', 'locations', 'factions', 'events', 'items'];
const entityColumns: Array<{ label: string; entries: Array<{ name: string; href: string }> }> = [];

for (const col of ENTITY_COLS) {
  const all = await getCollection(col);
  const filtered = all.filter((e: any) => {
    if (col === 'events') return e.data.campaign === campaignId;
    return e.data.campaigns?.includes(campaignId);
  });
  entityColumns.push({
    label: COLLECTIONS[col].label,
    entries: filtered
      .sort((a: any, b: any) => a.data.name.localeCompare(b.data.name))
      .map((e: any) => ({ name: e.data.name, href: entryUrl(col, e.id) })),
  });
}
---

<BaseLayout title={d.name}>
  <Breadcrumbs items={[
    { label: 'Home', href: baseUrl },
    ...(breadcrumbParent ? [breadcrumbParent] : []),
    { label: d.name },
  ]} />

  <!-- HEADER -->
  <div class="mb-8">
    <div class="flex items-start gap-3 mb-3">
      <h1 class="text-3xl lg:text-4xl font-serif text-accent">{d.name}</h1>
      <StatusBadge status={d.status} />
    </div>
    <div class="flex flex-wrap gap-x-6 gap-y-1 text-sm text-text-secondary">
      {d.session_count && <span>{d.session_count} sessions</span>}
      {d.start_date_real && <span>Started {d.start_date_real}</span>}
      {d.start_year && (
        <span>{d.start_year}{d.end_year ? `–${d.end_year}` : ''} TA</span>
      )}
      {d.continent && <span>{d.continent}</span>}
    </div>
    {d.current_date && (
      <p class="mt-2 text-sm">
        <span class="text-text-secondary">Current in-game date:</span>
        <span class="text-accent font-medium ml-1">{d.current_date}</span>
      </p>
    )}
  </div>

  <!-- OVERVIEW -->
  <section class="mb-10">
    <div class="entry-content">
      <Content />
    </div>
  </section>

  <!-- PARTY ROSTER -->
  {partyWithPortraits.length > 0 && (
    <section class="mb-10">
      <h2 class="text-xl font-serif text-accent mb-4 pb-2 border-b border-border">Party Roster</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {partyWithPortraits.map((member) => (
          <div class="bg-surface border border-border rounded-lg p-4 text-center hover:border-accent/50 transition-colors">
            {member.slug ? (
              <a href={entryUrl('pcs', member.slug)} class="block">
                {member.portrait ? (
                  <img
                    src={member.portrait}
                    alt={member.name}
                    class="w-20 h-20 rounded-full mx-auto mb-3 object-cover border-2 border-border"
                  />
                ) : (
                  <div class="w-20 h-20 rounded-full mx-auto mb-3 bg-border/50 flex items-center justify-center text-2xl font-serif text-text-secondary">
                    {member.initials}
                  </div>
                )}
                <p class="font-serif text-accent hover:text-accent-hover transition-colors">{member.name}</p>
              </a>
            ) : (
              <Fragment>
                <div class="w-20 h-20 rounded-full mx-auto mb-3 bg-border/50 flex items-center justify-center text-2xl font-serif text-text-secondary">
                  {member.initials}
                </div>
                <p class="font-serif text-text-primary">{member.name}</p>
              </Fragment>
            )}
            {member.player && <p class="text-text-secondary text-xs mt-0.5">{member.player}</p>}
            <p class="text-text-secondary text-xs mt-1">{member.race} {member.class}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- SESSION LOG -->
  <section class="mb-10">
    <h2 class="text-xl font-serif text-accent mb-4 pb-2 border-b border-border">Session Log</h2>

    <div class="flex flex-col lg:flex-row gap-6">
      <!-- Arc Sidebar -->
      {arcs.length > 0 && (
        <aside class="lg:w-56 shrink-0 order-last lg:order-first">
          <div class="lg:sticky lg:top-20 bg-surface border border-border rounded-lg p-4">
            <h3 class="text-xs uppercase tracking-wider text-accent font-semibold mb-3 pb-2 border-b border-border">Story Arcs</h3>
            <nav class="space-y-2">
              {arcs.map((arc) => (
                <div>
                  <p class="text-sm text-text-primary font-medium">{arc.name}</p>
                  <p class="text-xs text-text-secondary">Sessions {arc.sessions}</p>
                </div>
              ))}
            </nav>
          </div>
        </aside>
      )}

      <!-- Recap Cards -->
      <div class="flex-1">
        {recapsWithContent.length > 0 ? (
          <div class="space-y-2">
            {recapsWithContent.map(({ data, rendered: { Content } }) => (
              <details class="group bg-surface border border-border rounded-lg overflow-hidden">
                <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer hover:bg-surface-hover transition-colors [&::-webkit-details-marker]:hidden list-none">
                  <span class="text-accent font-serif font-semibold shrink-0 w-8">#{data.session_number}</span>
                  <span class="text-text-primary font-medium truncate flex-1">{data.name}</span>
                  {data.arc_name && (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-accent/10 text-accent hidden sm:inline shrink-0">{data.arc_name}</span>
                  )}
                  <span class="text-text-secondary text-xs shrink-0 hidden md:inline">{data.in_game_date ?? data.session_date}</span>
                  <svg class="w-4 h-4 text-text-secondary shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="px-4 pb-4 pt-2 border-t border-border/50 entry-content">
                  <Content />
                </div>
              </details>
            ))}
          </div>
        ) : (
          <p class="text-text-secondary text-sm italic">Session recaps coming soon.</p>
        )}
      </div>
    </div>
  </section>

  <!-- REGIONAL MAP -->
  {campaignMaps.length > 0 && (
    <section class="mb-10">
      <h2 class="text-xl font-serif text-accent mb-4 pb-2 border-b border-border">Regional Map</h2>
      <div class={`grid gap-4 ${campaignMaps.length > 1 ? 'grid-cols-1 lg:grid-cols-2' : 'grid-cols-1 max-w-2xl'}`}>
        {campaignMaps.map((m) => (
          <a href={`${baseUrl}map/`} class="block group">
            <div class="overflow-hidden rounded-lg border border-border group-hover:border-accent/50 transition-colors">
              <img
                src={`${baseUrl}maps/${m.file}`}
                alt={`Map of ${m.label}`}
                class="w-full h-auto transition-transform duration-300 group-hover:scale-[1.02]"
              />
            </div>
            <p class="text-xs text-text-secondary mt-1 group-hover:text-accent transition-colors">{m.label}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- CAMPAIGN GRIMOIRE (Tabbed) -->
  <section class="mb-10">
    <h2 class="text-xl font-serif text-accent mb-4 pb-2 border-b border-border">Campaign Grimoire</h2>

    <!-- Tabs -->
    <div class="flex flex-wrap gap-2 mb-6" id="grimoire-tabs">
      {entityColumns.map((col, i) => (
        <button
          data-tab={col.label}
          class={`grimoire-tab px-4 py-1.5 text-sm rounded-full transition-colors ${i === 0 ? 'bg-accent text-bg font-medium' : 'border border-border text-text-secondary hover:border-accent/50 hover:text-text-primary'}`}
        >
          {col.label} ({col.entries.length})
        </button>
      ))}
    </div>

    <!-- Tab Panels -->
    {entityColumns.map((col, i) => (
      <div class={`grimoire-panel ${i === 0 ? '' : 'hidden'}`} data-panel={col.label}>
        <ul class="columns-1 sm:columns-2 lg:columns-3 gap-x-8">
          {col.entries.map((e) => (
            <li class="mb-1 break-inside-avoid">
              <a href={e.href} class="text-sm text-text-secondary hover:text-accent transition-colors">{e.name}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>
</BaseLayout>

<script is:inline>
  const tabs = document.getElementById('grimoire-tabs');
  if (tabs) {
    tabs.addEventListener('click', (e) => {
      const btn = e.target.closest('.grimoire-tab');
      if (!btn) return;
      const target = btn.getAttribute('data-tab');

      // Update tab styles
      tabs.querySelectorAll('.grimoire-tab').forEach((t) => {
        const isActive = t.getAttribute('data-tab') === target;
        t.className = isActive
          ? 'grimoire-tab px-4 py-1.5 text-sm rounded-full bg-accent text-bg font-medium transition-colors'
          : 'grimoire-tab px-4 py-1.5 text-sm rounded-full border border-border text-text-secondary hover:border-accent/50 hover:text-text-primary transition-colors';
      });

      // Show/hide panels
      document.querySelectorAll('.grimoire-panel').forEach((p) => {
        p.classList.toggle('hidden', p.getAttribute('data-panel') !== target);
      });
    });
  }
</script>
