---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import EntryCard from '../../components/ui/EntryCard.astro';
import { getCollection } from 'astro:content';
import { entryUrl, CAMPAIGN_LABELS } from '../../lib/collections';

const entries = await getCollection('events');
const sorted = [...entries].sort((a, b) => {
  const yearDiff = (b.data.year ?? 0) - (a.data.year ?? 0);
  if (yearDiff !== 0) return yearDiff;
  return a.data.name.localeCompare(b.data.name);
});
const baseUrl = import.meta.env.BASE_URL;

const allCampaigns = [...new Set(entries.map((e) => e.data.campaign).filter(Boolean))].sort() as string[];
const allSignificance = [...new Set(entries.map((e) => e.data.significance))].sort();
---

<BaseLayout title="Events">
  <Breadcrumbs items={[{ label: 'Home', href: baseUrl }, { label: 'Events' }]} />

  <div class="flex items-baseline justify-between mb-6">
    <h1 class="text-3xl font-serif text-accent">Events</h1>
    <span class="text-text-secondary text-sm">{entries.length} entries</span>
  </div>

  <div class="flex flex-wrap gap-3 mb-6">
    <select id="filter-significance" class="bg-surface border border-border rounded-lg px-3 py-1.5 text-sm text-text-primary">
      <option value="">All Significance</option>
      {allSignificance.map((s) => <option value={s} class="capitalize">{s}</option>)}
    </select>
    <select id="filter-campaign" class="bg-surface border border-border rounded-lg px-3 py-1.5 text-sm text-text-primary">
      <option value="">All Campaigns</option>
      {allCampaigns.map((c) => <option value={c}>{CAMPAIGN_LABELS[c] ?? c}</option>)}
    </select>
    <input id="filter-name" type="text" placeholder="Search by name..." class="bg-surface border border-border rounded-lg px-3 py-1.5 text-sm text-text-primary flex-1 min-w-[160px]" />
  </div>

  <div id="entries-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
    {sorted.map((entry) => {
      const subtitle = [
        entry.data.date ?? (entry.data.year ? `${entry.data.year} TA` : null),
        entry.data.location,
      ].filter(Boolean).join(' · ');
      const sigColors = {
        major: 'bg-accent/20 text-accent',
        minor: 'bg-status-unknown/20 text-status-unknown',
        background: 'bg-border/50 text-text-secondary',
      };
      return (
        <EntryCard
          href={entryUrl('events', entry.id)}
          name={entry.data.name}
          subtitle={subtitle || undefined}
          badges={[
            { label: entry.data.significance, color: (sigColors as any)[entry.data.significance] ?? '' },
            ...(entry.data.campaign ? [{ label: CAMPAIGN_LABELS[entry.data.campaign] ?? entry.data.campaign }] : []),
          ]}
          data-significance={entry.data.significance}
          data-campaigns={entry.data.campaign ?? ''}
          data-name={entry.data.name.toLowerCase()}
        />
      );
    })}
  </div>

  <p id="no-results" class="text-text-secondary text-center py-8 hidden">No matching entries found.</p>
</BaseLayout>

<script is:inline>
  const grid = document.getElementById('entries-grid');
  const noResults = document.getElementById('no-results');
  const filterSig = document.getElementById('filter-significance');
  const filterCampaign = document.getElementById('filter-campaign');
  const filterName = document.getElementById('filter-name');

  function applyFilters() {
    const sig = filterSig.value;
    const campaign = filterCampaign.value;
    const name = filterName.value.toLowerCase();
    let visible = 0;

    grid.querySelectorAll('.entry-card').forEach((card) => {
      const show =
        (!sig || card.getAttribute('data-significance') === sig) &&
        (!campaign || (card.getAttribute('data-campaigns') || '').split(',').includes(campaign)) &&
        (!name || (card.getAttribute('data-name') || '').includes(name));

      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    noResults.classList.toggle('hidden', visible > 0);
  }

  filterSig.addEventListener('change', applyFilters);
  filterCampaign.addEventListener('change', applyFilters);
  filterName.addEventListener('input', applyFilters);
</script>
