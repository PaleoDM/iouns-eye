---
import { getCollection, render } from 'astro:content';
import EntryLayout from '../../layouts/EntryLayout.astro';
import MetadataSidebar from '../../components/ui/MetadataSidebar.astro';
import { entryUrl, isDefunctOnly } from '../../lib/collections';

export async function getStaticPaths() {
  const entries = await getCollection('items');
  const sorted = [...entries].sort((a, b) => a.data.name.localeCompare(b.data.name));
  return sorted.map((entry, i) => ({
    params: { id: entry.id },
    props: {
      entry,
      prevEntry: i > 0 ? { name: sorted[i - 1].data.name, href: entryUrl('items', sorted[i - 1].id) } : null,
      nextEntry: i < sorted.length - 1 ? { name: sorted[i + 1].data.name, href: entryUrl('items', sorted[i + 1].id) } : null,
    },
  }));
}

const { entry, prevEntry, nextEntry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
---

<EntryLayout
  title={d.name}
  collection="items"
  related={d.related}
  prevEntry={prevEntry}
  nextEntry={nextEntry}
  pagefindIgnore={isDefunctOnly(d)}
>
  <MetadataSidebar slot="sidebar" fields={[
    { label: 'Type', value: d.item_type, type: 'badge' },
    { label: 'Rarity', value: d.rarity?.replace('-', ' '), type: 'badge' },
    { label: 'Attunement', value: d.attunement ? 'Required' : undefined },
    { label: 'Current Holder', value: d.current_holder, type: 'slug' },
    { label: 'Campaign', value: d.campaign ? [d.campaign] : undefined, type: 'campaigns' },
    { label: 'Tags', value: d.tags, type: 'tags' },
  ]} />

  <Content slot="content" />
</EntryLayout>
