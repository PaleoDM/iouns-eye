---
import { getCollection, render } from 'astro:content';
import EntryLayout from '../../layouts/EntryLayout.astro';
import MetadataSidebar from '../../components/ui/MetadataSidebar.astro';
import { entryUrl, isDefunctOnly } from '../../lib/collections';

export async function getStaticPaths() {
  const entries = await getCollection('pcs');
  const sorted = [...entries].sort((a, b) => a.data.name.localeCompare(b.data.name));
  return sorted.map((entry, i) => ({
    params: { id: entry.id },
    props: {
      entry,
      prevEntry: i > 0 ? { name: sorted[i - 1].data.name, href: entryUrl('pcs', sorted[i - 1].id) } : null,
      nextEntry: i < sorted.length - 1 ? { name: sorted[i + 1].data.name, href: entryUrl('pcs', sorted[i + 1].id) } : null,
    },
  }));
}

const { entry, prevEntry, nextEntry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
---

<EntryLayout
  title={d.name}
  collection="pcs"
  related={d.related}
  prevEntry={prevEntry}
  nextEntry={nextEntry}
  pagefindIgnore={isDefunctOnly(d)}
>
  <MetadataSidebar slot="sidebar" fields={[
    { label: 'Race', value: d.race },
    { label: 'Class', value: d.subclass ? `${d.class} (${d.subclass})` : d.class },
    { label: 'Level', value: d.level },
    { label: 'Player', value: d.player },
    { label: 'Background', value: d.background },
    { label: 'Faction', value: d.faction, type: 'slug' },
    { label: 'Location', value: d.location, type: 'slug' },
    { label: 'Campaign', value: [d.campaign], type: 'campaigns' },
    { label: 'Tags', value: d.tags, type: 'tags' },
  ]} />

  <Content slot="content" />
</EntryLayout>
