---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import EntryCard from '../../components/ui/EntryCard.astro';
import { getCollection } from 'astro:content';
import { entryUrl, CAMPAIGN_LABELS } from '../../lib/collections';

const entries = await getCollection('pcs');
const sorted = [...entries].sort((a, b) => a.data.name.localeCompare(b.data.name));
const baseUrl = import.meta.env.BASE_URL;

const allCampaigns = [...new Set(entries.map((e) => e.data.campaign))].sort();
---

<BaseLayout title="Player Characters">
  <Breadcrumbs items={[{ label: 'Home', href: baseUrl }, { label: 'Player Characters' }]} />

  <div class="flex items-baseline justify-between mb-6">
    <h1 class="text-3xl font-serif text-accent">Player Characters</h1>
    <span class="text-text-secondary text-sm">{entries.length} entries</span>
  </div>

  <div class="flex flex-wrap gap-3 mb-6">
    <select id="filter-campaign" class="bg-surface border border-border rounded-lg px-3 py-1.5 text-sm text-text-primary">
      <option value="">All Campaigns</option>
      {allCampaigns.map((c) => <option value={c}>{CAMPAIGN_LABELS[c] ?? c}</option>)}
    </select>
    <input id="filter-name" type="text" placeholder="Search by name..." class="bg-surface border border-border rounded-lg px-3 py-1.5 text-sm text-text-primary flex-1 min-w-[160px]" />
  </div>

  <div id="entries-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
    {sorted.map((entry) => {
      const subtitle = `${entry.data.race} ${entry.data.class}${entry.data.subclass ? ` (${entry.data.subclass})` : ''}`;
      const badges = [
        { label: CAMPAIGN_LABELS[entry.data.campaign] ?? entry.data.campaign, color: 'bg-accent/20 text-accent' },
        ...(entry.data.level ? [{ label: `Lvl ${entry.data.level}` }] : []),
      ];
      return (
        <EntryCard
          href={entryUrl('pcs', entry.id)}
          name={entry.data.name}
          subtitle={subtitle}
          badges={badges}
          data-campaigns={entry.data.campaign}
          data-name={entry.data.name.toLowerCase()}
        />
      );
    })}
  </div>

  <p id="no-results" class="text-text-secondary text-center py-8 hidden">No matching entries found.</p>
</BaseLayout>

<script is:inline>
  const grid = document.getElementById('entries-grid');
  const noResults = document.getElementById('no-results');
  const filterCampaign = document.getElementById('filter-campaign');
  const filterName = document.getElementById('filter-name');

  function applyFilters() {
    const campaign = filterCampaign.value;
    const name = filterName.value.toLowerCase();
    let visible = 0;

    grid.querySelectorAll('.entry-card').forEach((card) => {
      const show =
        (!campaign || (card.getAttribute('data-campaigns') || '').split(',').includes(campaign)) &&
        (!name || (card.getAttribute('data-name') || '').includes(name));
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    noResults.classList.toggle('hidden', visible > 0);
  }

  filterCampaign.addEventListener('change', applyFilters);
  filterName.addEventListener('input', applyFilters);
</script>
