---
import BaseLayout from '../layouts/BaseLayout.astro';
import AstorianCalendar from '../components/calendar/AstorianCalendar';
import { getCollection } from 'astro:content';
import { entryUrl } from '../lib/collections';
import calendarData from '../data/calendar.json';
import { parseAstoranDate } from '../components/calendar/calendar-utils';

// Query all events and parse their dates
const allEvents = await getCollection('events');

const calendarEvents = allEvents.map((event) => {
  let day: number | undefined;
  let monthNumber: number | undefined;

  if (event.data.date) {
    const dateStr = typeof event.data.date === 'string' ? event.data.date : String(event.data.date);
    const parsed = parseAstoranDate(dateStr);
    if (parsed) {
      day = parsed.day;
      monthNumber = parsed.monthNumber;
    }
  }

  return {
    slug: event.id,
    name: event.data.name,
    day,
    monthNumber,
    year: event.data.year ?? 0,
    significance: event.data.significance ?? 'minor',
    url: entryUrl('events', event.id),
  };
}).filter((e) => e.year > 0);

const defaultYear = 1136;

const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title="Calendar" description="The Astorian calendar — 14 months, 392 days, tracked by the Celestial Braid">
  <div data-pagefind-ignore>
    <AstorianCalendar
      client:load
      calendarData={calendarData}
      events={calendarEvents}
      defaultYear={defaultYear}
      baseUrl={baseUrl}
    />
  </div>
</BaseLayout>
