---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import EntryCard from '../../components/ui/EntryCard.astro';
import { getCollection } from 'astro:content';
import { entryUrl, CAMPAIGN_LABELS } from '../../lib/collections';

const entries = await getCollection('factions');
const sorted = [...entries].sort((a, b) => a.data.name.localeCompare(b.data.name));
const baseUrl = import.meta.env.BASE_URL;

const allTypes = [...new Set(entries.map((e) => e.data.faction_type))].sort();
const allStatuses = [...new Set(entries.map((e) => e.data.status))].sort();
const allCampaigns = [...new Set(entries.flatMap((e) => e.data.campaigns))].sort();
---

<BaseLayout title="Factions">
  <Breadcrumbs items={[{ label: 'Home', href: baseUrl }, { label: 'Factions' }]} />

  <div class="flex items-baseline justify-between mb-6">
    <h1 class="text-3xl font-serif text-accent">Factions</h1>
    <span class="text-text-secondary text-sm">{entries.length} entries</span>
  </div>

  <div class="flex flex-wrap gap-3 mb-6">
    <select id="filter-type" class="bg-surface border border-border rounded-lg px-3 py-1.5 text-sm text-text-primary">
      <option value="">All Types</option>
      {allTypes.map((t) => <option value={t} class="capitalize">{t}</option>)}
    </select>
    <select id="filter-status" class="bg-surface border border-border rounded-lg px-3 py-1.5 text-sm text-text-primary">
      <option value="">All Statuses</option>
      {allStatuses.map((s) => <option value={s} class="capitalize">{s}</option>)}
    </select>
    <select id="filter-campaign" class="bg-surface border border-border rounded-lg px-3 py-1.5 text-sm text-text-primary">
      <option value="">All Campaigns</option>
      {allCampaigns.map((c) => <option value={c}>{CAMPAIGN_LABELS[c] ?? c}</option>)}
    </select>
    <input id="filter-name" type="text" placeholder="Search by name..." class="bg-surface border border-border rounded-lg px-3 py-1.5 text-sm text-text-primary flex-1 min-w-[160px]" />
  </div>

  <div id="entries-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
    {sorted.map((entry) => {
      const statusColors = {
        active: 'bg-status-alive/20 text-status-alive',
        disbanded: 'bg-status-dead/20 text-status-dead',
        hidden: 'bg-status-unknown/20 text-status-unknown',
        historical: 'bg-status-unknown/20 text-status-unknown',
      };
      return (
        <EntryCard
          href={entryUrl('factions', entry.id)}
          name={entry.data.name}
          subtitle={entry.data.leader ? `Led by ${entry.data.leader}` : undefined}
          badges={[
            { label: entry.data.faction_type },
            { label: entry.data.status, color: (statusColors as any)[entry.data.status] ?? '' },
          ]}
          data-type={entry.data.faction_type}
          data-status={entry.data.status}
          data-campaigns={entry.data.campaigns.join(',')}
          data-name={entry.data.name.toLowerCase()}
        />
      );
    })}
  </div>

  <p id="no-results" class="text-text-secondary text-center py-8 hidden">No matching entries found.</p>
</BaseLayout>

<script is:inline>
  const grid = document.getElementById('entries-grid');
  const noResults = document.getElementById('no-results');
  const filterType = document.getElementById('filter-type');
  const filterStatus = document.getElementById('filter-status');
  const filterCampaign = document.getElementById('filter-campaign');
  const filterName = document.getElementById('filter-name');

  function applyFilters() {
    const type = filterType.value;
    const status = filterStatus.value;
    const campaign = filterCampaign.value;
    const name = filterName.value.toLowerCase();
    let visible = 0;

    grid.querySelectorAll('.entry-card').forEach((card) => {
      const show =
        (!type || card.getAttribute('data-type') === type) &&
        (!status || card.getAttribute('data-status') === status) &&
        (!campaign || (card.getAttribute('data-campaigns') || '').split(',').includes(campaign)) &&
        (!name || (card.getAttribute('data-name') || '').includes(name));

      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    noResults.classList.toggle('hidden', visible > 0);
  }

  filterType.addEventListener('change', applyFilters);
  filterStatus.addEventListener('change', applyFilters);
  filterCampaign.addEventListener('change', applyFilters);
  filterName.addEventListener('input', applyFilters);
</script>
